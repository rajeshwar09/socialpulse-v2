# YouTube API
YOUTUBE_API_KEY=
YOUTUBE_SEARCH_RESULTS_PER_QUERY=5
YOUTUBE_COMMENTS_PER_VIDEO=20
YOUTUBE_MAX_QUERIES_PER_RUN=3
YOUTUBE_PUBLISHED_LOOKBACK_DAYS=7

# Project
SOCIALPULSE_ENV=dev
SOCIALPULSE_APP_NAME=SocialPulse V2
SOCIALPULSE_TIMEZONE=Asia/Kolkata

# Storage
SOCIALPULSE_DATA_ROOT=./data
SOCIALPULSE_LOG_LEVEL=INFO

# Dashboard
SOCIALPULSE_DASHBOARD_THEME=dark

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_YOUTUBE_COMMENTS=socialpulse.youtube.comments.raw
KAFKA_PRODUCER_CLIENT_ID=socialpulse-youtube-producer
KAFKA_CONSUMER_GROUP_ID=socialpulse-youtube-bronze-consumer
KAFKA_CONSUMER_TIMEOUT_MS=5000